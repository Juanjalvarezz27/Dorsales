generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Corredor {
  id                  String   @id @default(cuid())
  correo              String?
  nombre              String
  cedula              String   
  fechaNacimiento     String?  // Lo dejamos como String para facilitar la importación directa
  genero              String?
  telefono            String?
  contactoEmergencia  String?
  modalidad           String?  // Ej: Corriendo (Competitivo) / Caminando (Recreativo)
  club                String?
  
  // Campos de logística (Los que controlará el sistema)
  dorsal              String?  @unique // El número de corredor asignado (nulo al inicio)
  entregado           Boolean  @default(false) // Cambiará a true cuando se asigne el dorsal

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}